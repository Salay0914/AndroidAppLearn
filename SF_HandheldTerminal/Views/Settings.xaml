<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SF_HandheldTerminal.Views.Settings.Settings"
             xmlns:buttons="clr-namespace:Syncfusion.Maui.Toolkit.Buttons;assembly=Syncfusion.Maui.Toolkit"
             xmlns:cable="clr-namespace:SF_HandheldTerminal.Models.Cable"
             xmlns:local="clr-namespace:SF_HandheldTerminal"
             x:DataType="local:SettingsViewModel">

    <ContentView.Content>
        <Grid RowDefinitions="Auto,*" BackgroundColor="{DynamicResource SurfacePage}">

            <!-- ===== AppBar ===== -->
            <Border Grid.Row="0" Style="{DynamicResource CableAppBarBorderStyle}">
                <Label Text="设置" Style="{DynamicResource CableAppBarTitleStyle}" />
            </Border>

            <!-- ===== 内容 ===== -->
            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="0,4,0,16" Spacing="0"
                                     BindableLayout.ItemsSource="{Binding Groups}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="cable:SettingsGroup">
                            <VerticalStackLayout Spacing="0">
                                <Label Text="{Binding Title}" Style="{DynamicResource SettingsGroupHeaderStyle}" />

                                <Border BackgroundColor="{DynamicResource SurfaceCard}"
                                        Stroke="Transparent" StrokeThickness="0"
                                        StrokeShape="RoundRectangle 12"
                                        Margin="12,0,12,4"
                                        Padding="0">
                                    <VerticalStackLayout Spacing="0"
                                                         BindableLayout.ItemsSource="{Binding}">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="cable:SettingsItem">
                                                <VerticalStackLayout>
                                                    <Grid ColumnDefinitions="Auto,*,Auto,18" Padding="14,12" ColumnSpacing="10">
                                                        <Grid.GestureRecognizers>
                                                            <TapGestureRecognizer Tapped="OnSettingsItemTapped" />
                                                        </Grid.GestureRecognizers>
                                                        <Label Grid.Column="0" Text="{Binding IconGlyph}"
                                                               Style="{DynamicResource SettingsIconLabelStyle}" />
                                                        <Label Grid.Column="1" Text="{Binding Title}"
                                                               Style="{DynamicResource SettingsItemTitleStyle}" />
                                                        <Label Grid.Column="2" Text="{Binding ValueText}"
                                                               Style="{DynamicResource SettingsItemValueStyle}" />
                                                        <Label Grid.Column="3"
                                                               Style="{DynamicResource SettingsChevronLabelStyle}"
                                                               IsVisible="{Binding ShowChevron}" />
                                                    </Grid>
                                                    <BoxView HeightRequest="1"
                                                             Color="{DynamicResource DividerLine}"
                                                             Margin="44,0,0,0" />
                                                </VerticalStackLayout>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </VerticalStackLayout>
                                </Border>
                            </VerticalStackLayout>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>

                    <!-- 退出登录按钮 -->
                    <buttons:SfButton Text="退出登录"
                                      Style="{DynamicResource CableDangerOutlineButtonStyle}"
                                      Margin="12,18,12,0"
                                      Command="{Binding LogoutCommand}" />
                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </ContentView.Content>
</ContentView>
