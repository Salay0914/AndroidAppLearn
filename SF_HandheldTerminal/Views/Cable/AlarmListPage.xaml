<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SF_HandheldTerminal.Views.Cable.AlarmListPage"
             BackgroundColor="{DynamicResource SurfacePage}"
             Title="告警列表">
    <ScrollView>
        <VerticalStackLayout Padding="12,12,12,16" Spacing="12">
            <Border Style="{DynamicResource CableCardBorderStyle}" Padding="20">
                <VerticalStackLayout Spacing="6">
                    <Label Text="告警列表" Style="{DynamicResource CableSectionTitleStyle}" />
                    <Label Text="此页面待与告警服务接入后实现。" Style="{DynamicResource CableMetaTextStyle}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
