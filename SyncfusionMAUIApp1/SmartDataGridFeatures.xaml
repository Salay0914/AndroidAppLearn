<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:syncfusion="clr-namespace:Syncfusion.Maui.SmartComponents;assembly=Syncfusion.Maui.SmartComponents"
			 xmlns:dataGrid="clr-namespace:Syncfusion.Maui.DataGrid;assembly=Syncfusion.Maui.DataGrid"
			 xmlns:editors="clr-namespace:Syncfusion.Maui.Inputs;assembly=Syncfusion.Maui.Inputs"
             xmlns:local="clr-namespace:SyncfusionMAUIApp1" Title="SmartDataGrid"
             x:Class="SyncfusionMAUIApp1.SmartDataGridFeatures">
    <ContentPage.BindingContext>
        <local:SmartOrderInfoRepository x:Name="viewModel"/>
    </ContentPage.BindingContext>
	<ContentPage.Content>
        <Grid RowDefinitions="50, *">
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
            </Grid>
			<syncfusion:SfSmartDataGrid x:Name="smartGrid" ItemsSource="{Binding OrderInfoCollection}"
                                       Grid.Row="1"
                                       HeaderGridLinesVisibility="Both"
                                       GridLinesVisibility="Both"
                                       ColumnWidthMode="FitByHeader"
                                   AutoGenerateColumnsMode="None">
				<syncfusion:SfSmartDataGrid.AssistViewSettings>
					<syncfusion:DataGridAssistViewSettings SuggestedPrompts="{Binding Suggestions}"/>
				</syncfusion:SfSmartDataGrid.AssistViewSettings>
				<dataGrid:SfDataGrid.DefaultStyle>
                    <dataGrid:DataGridStyle HeaderRowFontAttributes="Bold"/>
                </dataGrid:SfDataGrid.DefaultStyle>
				<dataGrid:SfDataGrid.Columns>
                    <dataGrid:DataGridNumericColumn HeaderText="Order ID"
                                          MappingName="OrderID" />
                    <dataGrid:DataGridTextColumn  HeaderText="Customer ID"
                                        MappingName="CustomerID" />
                    <dataGrid:DataGridTextColumn  HeaderText="Customer"
                                        MappingName="Customer" />
                    <dataGrid:DataGridTextColumn  HeaderText="Ship City"
                                        MappingName="ShipCity" />
                    <dataGrid:DataGridTextColumn  HeaderText="Ship Country"
                                        MappingName="ShipCountry" />
                </dataGrid:SfDataGrid.Columns>
            </syncfusion:SfSmartDataGrid>
        </Grid>
    </ContentPage.Content>
</ContentPage>
