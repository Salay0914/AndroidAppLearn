<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="OutdoorBackground">#F4F6F8</Color>
    <Color x:Key="OutdoorText">#0B1220</Color>
    <Color x:Key="OutdoorAccent">#0F6CBD</Color>

    <Style x:Key="OutdoorTitleLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource OutdoorText}" />
        <Setter Property="FontSize" Value="26" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <Style x:Key="OutdoorCaptionLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource Gray600}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <Style x:Key="OutdoorPrimaryButton" TargetType="Button">
        <Setter Property="TextColor" Value="{StaticResource White}" />
        <Setter Property="BackgroundColor" Value="{StaticResource OutdoorAccent}" />
        <Setter Property="MinimumHeightRequest" Value="52" />
        <Setter Property="Padding" Value="18,14" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="CornerRadius" Value="10" />
    </Style>

    <Style x:Key="OutdoorSecondaryButton" TargetType="Button">
        <Setter Property="TextColor" Value="{StaticResource OutdoorText}" />
        <Setter Property="BackgroundColor" Value="{StaticResource Gray300}" />
        <Setter Property="MinimumHeightRequest" Value="52" />
        <Setter Property="Padding" Value="18,14" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="CornerRadius" Value="10" />
    </Style>

    <Style x:Key="OutdoorEntry" TargetType="Entry">
        <Setter Property="MinimumHeightRequest" Value="52" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="BackgroundColor" Value="{StaticResource White}" />
        <Setter Property="TextColor" Value="{StaticResource OutdoorText}" />
    </Style>
</ResourceDictionary>
